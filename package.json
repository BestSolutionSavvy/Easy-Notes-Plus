{
  "name": "easy-notes-plus",
  "description": "A modern desktop application for taking notes on PDF documents",
  "author": {
    "name": "BSS"
  },
  "version": "1.0.5",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "electron": "wait-on http://localhost:5173 && electron .",
    "dev:electron": "concurrently \"pnpm dev\" \"pnpm electron\"",
    "dist": "pnpm build && electron-builder",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "electron-updater": "^6.8.3",
    "marked": "^17.0.2",
    "pdf-lib": "^1.17.1",
    "tailwindcss": "^4.1.18",
    "vue": "^3.5.28",
    "vue-pdf-embed": "^2.1.3",
    "vue-router": "^5.0.2"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.10.13",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.46.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.47.0",
    "postcss": "^8.5.6",
    "prettier": "3.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vue-tsc": "^3.2.4",
    "wait-on": "^8.0.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "build": {
    "appId": "com.bss.easy-notes-plus",
    "productName": "Easy Notes Plus",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "public/favicon.ico",
        "to": "favicon.ico"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "BestSolutionSavvy",
      "repo": "easy-notes-plus"
    },
    "win": {
      "icon": "public/faviconx256.ico",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "public/logo.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "icon": "public/logo.png",
      "category": "Office"
    }
  }
}
